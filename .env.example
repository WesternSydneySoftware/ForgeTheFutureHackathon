# Server
PORT=3000

# Elasticsearch (Elastic Cloud)
# Prefer Cloud ID + API Key:
# ELASTICSEARCH_CLOUD_ID=cluster-name:base64(...)
# ELASTICSEARCH_API_KEY=base64ApiKey
#
# Or direct node URL:
# ELASTICSEARCH_NODE=https://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

# Index
ES_JOBS_INDEX=omj-jobs


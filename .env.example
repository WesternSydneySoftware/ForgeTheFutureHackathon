# Server
PORT=3000

# Elasticsearch (Elastic Cloud)
# Prefer Cloud ID + API Key:
# ELASTICSEARCH_CLOUD_ID=cluster-name:base64(...)
# ELASTICSEARCH_API_KEY=base64ApiKey
#
# Or direct node URL:
# ELASTICSEARCH_NODE=https://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

# Index
ES_JOBS_INDEX=omj-jobs

# Geocoding (customer address -> lat/lon)
# Defaults to OpenStreetMap Nominatim.
# GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
# GEOCODER_USER_AGENT=EnRouteHackathon/0.1 (contact: you@example.com)

# Routing (tradie route -> jobs along route)
# Defaults to OSRM public demo server.
# ROUTER_BASE_URL=https://router.project-osrm.org
# ROUTE_AVG_SPEED_KPH=40

# Maps (browser)
# Google Maps JS API key (restrict by HTTP referrer in Google Cloud Console).
# GOOGLE_MAPS_API_KEY=
